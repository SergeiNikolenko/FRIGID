+class _CompatCompositeMassSpec(dict):
+    """Small mapping wrapper compatible with FRIGID's masking utilities."""
+
+    def __init__(self, specs: Any):
+        super().__init__()
+
+        if isinstance(specs, dict):
+            for ce, spec in specs.items():
